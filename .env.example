# ---------- Frontend ----------
VITE_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
VITE_API_BASE_URL="http://localhost:4020"

# ---------- Public API (Express) ----------
PORT=4020
LOG_LEVEL="info"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_BASE_URL="https://build.lewisnote.com/v1"
OPENAI_MODEL="gpt-5.4-mini"

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Auth user JWT (Clerk/JWKS)
AUTH_REQUIRED="false"
AUTH_BYPASS="true"
AUTH_JWKS_URI=""
AUTH_ISSUER=""
AUTH_AUDIENCE=""
AUTH_LEEWAY_SECONDS="60"
AUTH_STRICT_SCOPES="false"
AUTH_DEFAULT_SCOPES="chat:write,transcribe:write"

# Orchestration mode: legacy | hybrid | crewai
ORCHESTRATION_MODE="hybrid"
# Progressive rollout to orchestrator (0..100)
ORCHESTRATION_CREWAI_PERCENT="10"
ORCHESTRATOR_URL="http://127.0.0.1:8081"
ORCHESTRATOR_TIMEOUT_MS="45000"

# Internal service-to-service auth (public API -> orchestrator)
INTERNAL_AUTH_ISSUER="public-api"
INTERNAL_AUTH_AUDIENCE="crewai-orchestrator"
INTERNAL_AUTH_KID="v1"
INTERNAL_AUTH_TTL_SEC="90"
INTERNAL_AUTH_SHARED_SECRETS="change-me-1,change-me-2"

# Audio transcription hardening
ASR_API_KEY="YOUR_BUILD_LEWISNOTE_API_KEY"
ASR_MODEL="afri-asr"
ASR_ENDPOINT="https://build.lewisnote.com/v1/audio/afri-asr/transcribe"
ASR_TIMEOUT_MS="45000"
TRANSCRIBE_MAX_BYTES="10485760"

# Database (PostgreSQL)
DATABASE_ENABLED="true"
DATABASE_URL="postgresql://mindmesh:mindmesh@localhost:5432/mindmesh"
DATABASE_SSL="false"
DATABASE_INIT_MAX_RETRIES="3"
DATABASE_INIT_RETRY_MS="1500"
DB_LOG_RETENTION_DAYS="90"
DB_RETENTION_CLEANUP_INTERVAL_MIN="360"

# Rate limits
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_CHAT_MAX="30"
RATE_LIMIT_TRANSCRIBE_MAX="12"

# ---------- Orchestrator (FastAPI) ----------
ORCHESTRATOR_SERVICE_NAME="mindmesh-orchestrator"
ORCHESTRATOR_HOST="0.0.0.0"
ORCHESTRATOR_PORT="8081"
ORCHESTRATOR_LOG_LEVEL="INFO"
ORCHESTRATOR_ENGINE="auto"
INTERNAL_AUTH_LEEWAY_SEC="60"
