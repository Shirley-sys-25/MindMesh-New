{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,api \"vite --port=3000 --host=0.0.0.0\" \"node server.js\"",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "node server.js",
    "dev:orchestrator": "python -m uvicorn backend.orchestrator.app.main:app --host 0.0.0.0 --port 8081 --reload",
    "dev:full": "concurrently -n client,api,orchestrator \"vite --port=3000 --host=0.0.0.0\" \"node server.js\" \"python -m uvicorn backend.orchestrator.app.main:app --host 0.0.0.0 --port 8081 --reload\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test:api": "node --test backend/public-api/test/auth-and-routes.test.js backend/public-api/test/db-retention.service.test.js",
    "test:ops": "node --test scripts/ops/preflight.test.js",
    "test:orchestrator": "python -m unittest discover -s backend/orchestrator/tests -p \"test_*.py\" -v",
    "ops:preflight": "node scripts/ops/preflight.mjs --env-file .env --require-prod-flags",
    "ops:baseline": "node scripts/ops/rollout-gate.mjs baseline --api-base-url http://localhost:4020 --duration-sec 300 --interval-sec 10",
    "ops:evaluate": "node scripts/ops/rollout-gate.mjs evaluate --api-base-url http://localhost:4020 --duration-sec 300 --interval-sec 10"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.5",
    "@clerk/localizations": "^4.5.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jose": "^6.0.11",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
